# ── Provider ──────────────────────────────────────────────────────────────────
# Get your URL from https://webhook.site
PROVIDER_WEBHOOK_URL=https://webhook.site/YOUR-UUID-HERE
PROVIDER_TIMEOUT=10s

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=notification
DB_PASSWORD=notification
DB_NAME=notification_db
DB_SSL_MODE=disable

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=notifications
RABBITMQ_QUEUE_PREFIX=notifications
RABBITMQ_DLQ_PREFIX=notifications.dlq
RABBITMQ_PREFETCH=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=5
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY=5s
WORKER_RATE_LIMIT_PER_SEC=100
